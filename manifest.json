{
  "manifest_version": 3,
  "name": "Call of Roma Client Fixes",
  "version": "1.9.12",
  "description": "Fixes Call of Roma UI bugs, removes the external recharge ad, makes server-confirmed wilderness clearings open as wilds, adds Auto-Build and Auto-Job modes, and recovers from WebGL context loss.",
  "action": {
    "default_title": "Call of Roma Client Fixes"
  },
  "content_scripts": [
    {
      "matches": [
        "https://callofroma.com/*",
        "https://*.callofroma.com/*",
        "http://callofroma.com/*",
        "http://*.callofroma.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-patch.js"
      ],
      "matches": [
        "https://callofroma.com/*",
        "https://*.callofroma.com/*",
        "http://callofroma.com/*",
        "http://*.callofroma.com/*"
      ]
    }
  ]
}
