{
  "manifest_version": 3,
  "name": "Call of Roma Client Fixes",
  "version": "1.6.2",
  "description": "Fixes Call of Roma city sprites, stale arena reminders, campaign hero city selection, quest counts, and noisy ads.",
  "action": {
    "default_title": "Call of Roma Client Fixes"
  },
  "content_scripts": [
    {
      "matches": [
        "https://callofroma.com/*",
        "https://*.callofroma.com/*",
        "http://callofroma.com/*",
        "http://*.callofroma.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-patch.js"
      ],
      "matches": [
        "https://callofroma.com/*",
        "https://*.callofroma.com/*",
        "http://callofroma.com/*",
        "http://*.callofroma.com/*"
      ]
    }
  ]
}
